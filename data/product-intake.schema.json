{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://setupsahla.local/product-intake.schema.json",
  "title": "Product intake queue",
  "description": "Staging queue of products the owner adds via the dashboard. NOT canonical and NOT vault-sealed. The orchestrator promotes items into data/products.json only after the gates pass.",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": ["intakeId", "name", "category", "providers", "priority", "status", "createdAt"],
    "properties": {
      "intakeId": { "type": "string", "pattern": "^IN-\\d{4}-\\d{4}$" },
      "name": { "type": "string", "minLength": 1 },
      "category": { "type": "string", "minLength": 1 },
      "problemHypothesis": { "type": "string" },
      "providers": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["retailer", "productUrl", "affiliateKeyRef"],
          "properties": {
            "retailer": { "type": "string", "minLength": 1 },
            "productUrl": { "type": "string", "pattern": "^https?://" },
            "affiliateKeyRef": {
              "type": "string",
              "description": "A key into .vault/secrets.local.json affiliateLinks, NOT a URL. The real tracking link never lives here.",
              "not": { "pattern": "(?i)http" }
            }
          }
        }
      },
      "images": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "imageRights"],
          "properties": {
            "kind": { "enum": ["reference", "original"] },
            "sourceUrl": { "type": "string" },
            "imageRights": {
              "enum": ["ORIGINAL", "MANUFACTURER_PERMISSION_REVIEWED", "AFFILIATE_API", "SOURCE_LINK_ONLY"]
            }
          }
        }
      },
      "ownerNotes": { "type": "string" },
      "priority": { "enum": ["low", "medium", "high"] },
      "status": {
        "enum": ["new", "dispatched", "researching", "images", "drafting", "ready", "promoted", "rejected", "on-hold"]
      },
      "delegations": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "research": { "enum": ["requested", "in-progress", "done", "skipped"] },
          "creative": { "enum": ["requested", "in-progress", "done", "skipped"] },
          "marketing": { "enum": ["requested", "in-progress", "done", "skipped"] }
        }
      },
      "targetSlug": { "type": ["string", "null"] },
      "promotedProductId": { "type": ["string", "null"] },
      "createdAt": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}" }
    }
  }
}
