{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://setupsahla.example/schemas/product.schema.json",
  "title": "Setup Sahla launch product",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "candidateId",
    "slug",
    "route",
    "name",
    "category",
    "problem",
    "verdict",
    "bestFor",
    "skipIf",
    "brand",
    "model",
    "compatibility",
    "snapshotPriceEgp",
    "priceCapturedAt",
    "primaryKeyword",
    "supportingKeywords",
    "score",
    "providers",
    "evidence",
    "risks",
    "closestRejectedAlternative"
  ],
  "properties": {
    "candidateId": { "type": "string", "pattern": "^PP-C[0-9]{2}$" },
    "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "route": { "type": "string", "pattern": "^/products/[a-z0-9-]+/$" },
    "name": { "$ref": "#/$defs/nonEmptyString" },
    "category": { "$ref": "#/$defs/nonEmptyString" },
    "problem": { "$ref": "#/$defs/nonEmptyString" },
    "verdict": { "$ref": "#/$defs/nonEmptyString" },
    "bestFor": { "$ref": "#/$defs/nonEmptyStringArray" },
    "skipIf": { "$ref": "#/$defs/nonEmptyStringArray" },
    "brand": { "$ref": "#/$defs/nonEmptyString" },
    "model": { "$ref": "#/$defs/nonEmptyString" },
    "compatibility": { "$ref": "#/$defs/nonEmptyStringArray" },
    "snapshotPriceEgp": { "type": "number", "exclusiveMinimum": 0 },
    "priceCapturedAt": { "$ref": "#/$defs/date" },
    "primaryKeyword": { "$ref": "#/$defs/primaryKeyword" },
    "supportingKeywords": {
      "type": "array",
      "minItems": 4,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/nonEmptyString" }
    },
    "score": { "$ref": "#/$defs/score" },
    "providers": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": { "$ref": "#/$defs/provider" }
    },
    "evidence": {
      "type": "array",
      "minItems": 3,
      "items": { "$ref": "#/$defs/evidence" }
    },
    "risks": { "$ref": "#/$defs/nonEmptyStringArray" },
    "closestRejectedAlternative": { "$ref": "#/$defs/nonEmptyString" }
  },
  "$defs": {
    "nonEmptyString": { "type": "string", "minLength": 1, "pattern": ".*\\S.*" },
    "nonEmptyStringArray": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/nonEmptyString" }
    },
    "date": { "type": "string", "format": "date", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "dateTime": { "type": "string", "format": "date-time" },
    "uri": { "type": "string", "format": "uri", "pattern": "^https://" },
    "primaryKeyword": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidenceId", "keyword", "intent", "market", "metricName", "metricValue", "metricUnit", "sourceUrl", "capturedAt"],
      "properties": {
        "evidenceId": { "type": "string", "pattern": "^SEO-KW-[0-9]{3}$" },
        "keyword": { "$ref": "#/$defs/nonEmptyString" },
        "intent": { "$ref": "#/$defs/nonEmptyString" },
        "market": { "const": "EG" },
        "metricName": { "const": "google_autocomplete_presence" },
        "metricValue": { "const": "returned" },
        "metricUnit": { "const": "qualitative" },
        "sourceUrl": { "$ref": "#/$defs/uri" },
        "capturedAt": { "$ref": "#/$defs/dateTime" }
      }
    },
    "score": {
      "type": "object",
      "additionalProperties": false,
      "required": ["components", "total"],
      "properties": {
        "components": {
          "type": "object",
          "additionalProperties": false,
          "required": ["problemUrgency", "searchIntent", "availability", "value", "compatibility", "editorialFit", "visual"],
          "properties": {
            "problemUrgency": { "type": "integer", "minimum": 0, "maximum": 25 },
            "searchIntent": { "type": "integer", "minimum": 0, "maximum": 20 },
            "availability": { "type": "integer", "minimum": 0, "maximum": 15 },
            "value": { "type": "integer", "minimum": 0, "maximum": 15 },
            "compatibility": { "type": "integer", "minimum": 0, "maximum": 10 },
            "editorialFit": { "type": "integer", "minimum": 0, "maximum": 10 },
            "visual": { "type": "integer", "minimum": 0, "maximum": 5 }
          }
        },
        "total": { "type": "integer", "minimum": 0, "maximum": 100 }
      }
    },
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": ["retailer", "directUrl", "affiliateUrl", "affiliateStatus", "listingTitle", "sellerNotes", "priceEgp", "capturedAt", "imageSourceUrl", "imageRights"],
      "properties": {
        "retailer": { "enum": ["Amazon Egypt", "Noon Egypt"] },
        "directUrl": { "$ref": "#/$defs/uri" },
        "affiliateUrl": { "type": "null" },
        "affiliateStatus": { "const": "DIRECT_LINK — AFFILIATE ID REQUIRED" },
        "listingTitle": { "$ref": "#/$defs/nonEmptyString" },
        "sellerNotes": { "$ref": "#/$defs/nonEmptyString" },
        "priceEgp": { "type": "number", "exclusiveMinimum": 0 },
        "capturedAt": { "$ref": "#/$defs/date" },
        "imageSourceUrl": { "$ref": "#/$defs/uri" },
        "imageRights": { "const": "SOURCE_LINK_ONLY" }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidenceId", "claim", "sourceUrl", "capturedAt"],
      "properties": {
        "evidenceId": { "type": "string", "pattern": "^(PP-E|SEO-KW-|AFF-)[0-9]{3}$" },
        "claim": { "$ref": "#/$defs/nonEmptyString" },
        "sourceUrl": { "$ref": "#/$defs/uri" },
        "capturedAt": { "$ref": "#/$defs/dateTime" }
      }
    }
  }
}
